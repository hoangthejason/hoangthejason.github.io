---
import TagList from './TagList.astro';
import TableOfContents from './TableOfContents.astro';
import GiscusComments from './GiscusComments.astro';
import MermaidRenderer from './MermaidRenderer.astro';
import CodeBlockEnhancer from './CodeBlockEnhancer.astro';
import { formatDate } from '../lib/format';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface NavEntry {
  slug: string;
  data: {
    title: string;
  };
}

interface Props {
  title: string;
  description?: string;
  tags?: string[];
  date?: Date;
  updatedDate?: Date;
  readingTime?: number;
  headings?: Heading[];
  previous?: NavEntry | null;
  next?: NavEntry | null;
  previousUrl?: string | null;
  nextUrl?: string | null;
  comments?: boolean;
}

const {
  title,
  description,
  tags = [],
  date,
  updatedDate,
  readingTime,
  headings = [],
  previous = null,
  next = null,
  previousUrl = null,
  nextUrl = null,
  comments = false
} = Astro.props;
---

<div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_18rem]">
  <article class="min-w-0">
    <header class="border-b border-[var(--color-border)] pb-8">
      <p class="text-sm uppercase tracking-[0.18em] text-[var(--color-muted)]">Article</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-[var(--color-text)] md:text-5xl">
        {title}
      </h1>
      {description && <p class="mt-4 max-w-3xl text-lg leading-8 text-[var(--color-muted)]">{description}</p>}
      <div class="mt-5 flex flex-wrap items-center gap-3 text-sm text-[var(--color-muted)]">
        {date && <span>Published {formatDate(date)}</span>}
        {updatedDate && <span>Updated {formatDate(updatedDate)}</span>}
        {readingTime && <span>{readingTime} min read</span>}
      </div>
      <div class="mt-4">
        <TagList tags={tags} />
      </div>
      {headings.length > 0 && (
        <details class="mt-6 rounded-xl border border-[var(--color-border)] p-4 lg:hidden">
          <summary class="cursor-pointer text-sm font-medium text-[var(--color-text)]">Table of contents</summary>
          <div class="mt-4">
            <TableOfContents headings={headings} />
          </div>
        </details>
      )}
    </header>

    <div class="prose prose-neutral mt-10 max-w-none">
      <slot />
    </div>

    <footer class="mt-14 border-t border-[var(--color-border)] pt-8">
      <div class="grid gap-4 md:grid-cols-2">
        <a
          href={previousUrl || '#'}
          class:list={[
            'rounded-2xl border border-[var(--color-border)] p-4 transition',
            previousUrl ? 'hover:border-[var(--color-accent)]' : 'pointer-events-none opacity-50'
          ]}
        >
          <div class="text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Previous article</div>
          <div class="mt-2 text-lg font-medium text-[var(--color-text)]">
            {previous ? previous.data.title : '—'}
          </div>
        </a>

        <a
          href={nextUrl || '#'}
          class:list={[
            'rounded-2xl border border-[var(--color-border)] p-4 transition',
            nextUrl ? 'hover:border-[var(--color-accent)]' : 'pointer-events-none opacity-50'
          ]}
        >
          <div class="text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Next article</div>
          <div class="mt-2 text-lg font-medium text-[var(--color-text)]">
            {next ? next.data.title : '—'}
          </div>
        </a>
      </div>

      {comments && <GiscusComments />}
    </footer>
  </article>

  <aside class="hidden lg:block">
    <div class="sticky top-24">
      <TableOfContents headings={headings} />
    </div>
  </aside>
</div>

<MermaidRenderer />
<CodeBlockEnhancer />
