---
import { SITE } from '../site.config';
---

<footer class="border-t border-[var(--color-border)]">
  <div class="mx-auto flex max-w-6xl flex-col gap-4 px-4 py-8 text-sm text-[var(--color-muted)] md:flex-row md:items-center md:justify-between md:px-6">
    <p>© {new Date().getFullYear()} {SITE.author}. Built with Astro, Markdown, and static search.</p>
    <div class="flex items-center gap-4">
      <a href="/rss.xml" class="hover:text-[var(--color-text)]">RSS</a>
      <a href="/admin" class="hover:text-[var(--color-text)]">CMS</a>
      <a href="https://github.com/hoangthejason/hoangthejason.github.io" class="hover:text-[var(--color-text)]">GitHub</a>
    </div>
  </div>
</footer>
