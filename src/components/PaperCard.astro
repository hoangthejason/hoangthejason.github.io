---
import TagList from './TagList.astro';
import { formatDate } from '../lib/format';

interface Props {
  href: string;
  title: string;
  authors: string[];
  paperLink: string;
  problem: string;
  method: string;
  results: string;
  limitations: string;
  date?: Date;
  tags?: string[];
}

const {
  href,
  title,
  authors,
  paperLink,
  problem,
  method,
  results,
  limitations,
  date,
  tags = []
} = Astro.props;
---

<article class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg)] p-5 shadow-sm">
  <div class="flex flex-wrap items-center gap-3 text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">
    <span>Paper Note</span>
    {date && <span>{formatDate(date)}</span>}
  </div>
  <h2 class="mt-3 text-2xl font-semibold leading-tight">
    <a href={href} class="hover:text-[var(--color-brand)]">{title}</a>
  </h2>
  <p class="mt-2 text-sm text-[var(--color-muted)]">{authors.join(', ')}</p>
  <p class="mt-3 text-sm leading-7 text-[var(--color-muted)]">
    <span class="font-medium text-[var(--color-text)]">Problem:</span> {problem}
  </p>
  <p class="mt-2 text-sm leading-7 text-[var(--color-muted)]">
    <span class="font-medium text-[var(--color-text)]">Method:</span> {method}
  </p>
  <p class="mt-2 text-sm leading-7 text-[var(--color-muted)]">
    <span class="font-medium text-[var(--color-text)]">Results:</span> {results}
  </p>
  <p class="mt-2 text-sm leading-7 text-[var(--color-muted)]">
    <span class="font-medium text-[var(--color-text)]">Limitations:</span> {limitations}
  </p>
  <div class="mt-4 flex flex-wrap items-center gap-3">
    <a
      href={paperLink}
      class="text-sm font-medium text-[var(--color-brand)] underline decoration-from-font underline-offset-4"
      rel="noreferrer"
      target="_blank"
    >
      Open paper
    </a>
    <TagList tags={tags} />
  </div>
</article>
