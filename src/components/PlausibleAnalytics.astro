---
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
const plausibleSrc = import.meta.env.PUBLIC_PLAUSIBLE_SCRIPT_SRC || 'https://plausible.io/js/script.js';
---

{
  plausibleDomain && (
    <script
      defer
      data-domain={plausibleDomain}
      src={plausibleSrc}
    ></script>
  )
}
