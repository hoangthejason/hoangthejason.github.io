---
import TagList from './TagList.astro';
import { formatDate } from '../lib/format';

interface Props {
  href: string;
  title: string;
  description?: string;
  date?: Date;
  tags?: string[];
  meta?: string;
}

const { href, title, description, date, tags = [], meta } = Astro.props;
---

<article class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg)] p-5 shadow-sm transition hover:shadow-md">
  <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">
    {meta && <span>{meta}</span>}
    {date && <span>{formatDate(date)}</span>}
  </div>
  <h2 class="mt-3 text-2xl font-semibold leading-tight text-[var(--color-text)]">
    <a href={href} class="hover:text-[var(--color-brand)]">{title}</a>
  </h2>
  {description && <p class="mt-3 text-sm leading-7 text-[var(--color-muted)]">{description}</p>}
  <div class="mt-4">
    <TagList tags={tags} />
  </div>
</article>
