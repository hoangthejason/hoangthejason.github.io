---
import { slugify } from '../lib/format';

interface Props {
  tags?: string[];
}

const { tags = [] } = Astro.props;
---

{
  tags.length > 0 && (
    <ul class="flex flex-wrap gap-2" aria-label="Tags">
      {tags.map((tag) => (
        <li>
          <a
            href={`/tags/${slugify(tag)}`}
            class="inline-flex rounded-full border border-[var(--color-border)] px-2.5 py-1 text-xs font-medium text-[var(--color-muted)] transition hover:border-[var(--color-accent)] hover:text-[var(--color-text)]"
          >
            {tag}
          </a>
        </li>
      ))}
    </ul>
  )
}
