---
import BaseLayout from '../components/BaseLayout.astro';
---

<BaseLayout title="404" description="The requested page could not be found." noIndex={true}>
  <section class="max-w-2xl">
    <p class="text-sm uppercase tracking-[0.18em] text-[var(--color-muted)]">404</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight md:text-5xl">Page not found</h1>
    <p class="mt-4 text-lg leading-8 text-[var(--color-muted)]">
      The page you requested does not exist or the URL is incorrect.
    </p>
    <a
      href="/"
      class="mt-8 inline-flex rounded-lg border border-[var(--color-border)] px-4 py-2 text-sm font-medium text-[var(--color-text)] hover:border-[var(--color-accent)]"
    >
      Return home
    </a>
  </section>
</BaseLayout>
