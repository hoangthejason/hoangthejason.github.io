---
import BaseLayout from '../components/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const about = await getEntry('pages', 'about');
const { Content } = about ? await render(about) : { Content: null };
---

<BaseLayout title={about?.data.title || 'About'} description={about?.data.description}>
  <section class="max-w-4xl">
    <p class="text-sm uppercase tracking-[0.18em] text-[var(--color-muted)]">Profile</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight md:text-5xl">{about?.data.title || 'About'}</h1>
    {about?.data.description && <p class="mt-4 text-lg leading-8 text-[var(--color-muted)]">{about.data.description}</p>}

    <div class="mt-10 grid gap-8 md:grid-cols-[1.2fr_0.8fr]">
      <div class="prose prose-neutral max-w-none">
        {Content && <Content />}
      </div>

      <aside class="space-y-6">
        <section class="rounded-2xl border border-[var(--color-border)] p-5">
          <h2 class="text-xl font-semibold">Skills</h2>
          <ul class="mt-4 space-y-2 text-sm leading-7 text-[var(--color-muted)]">
            {(about?.data.skills || []).map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="rounded-2xl border border-[var(--color-border)] p-5">
          <h2 class="text-xl font-semibold">Research interests</h2>
          <ul class="mt-4 space-y-2 text-sm leading-7 text-[var(--color-muted)]">
            {(about?.data.researchInterests || []).map((item) => <li>{item}</li>)}
          </ul>
        </section>

        <section class="rounded-2xl border border-[var(--color-border)] p-5">
          <h2 class="text-xl font-semibold">Links</h2>
          <ul class="mt-4 space-y-2 text-sm leading-7">
            {(about?.data.links || []).map((item) => (
              <li>
                <a class="text-[var(--color-brand)] underline underline-offset-4" href={item.url}>
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </section>
      </aside>
    </div>
  </section>
</BaseLayout>
