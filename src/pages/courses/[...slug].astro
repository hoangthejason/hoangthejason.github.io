---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../components/BaseLayout.astro';
import ContentLayout from '../../components/ContentLayout.astro';
import { getNeighbors, getSortedCollection } from '../../lib/content';

export async function getStaticPaths() {
  const entries = await getCollection('courses', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

interface Props {
  entry: CollectionEntry<'courses'>;
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const entries = await getSortedCollection('courses');
const { previous, next } = getNeighbors(entries, entry.slug);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <ContentLayout
    title={entry.data.title}
    description={entry.data.description}
    tags={entry.data.tags}
    date={entry.data.date}
    updatedDate={entry.data.updatedDate}
    readingTime={entry.data.readingTime}
    headings={headings}
    previous={previous}
    next={next}
    previousUrl={previous ? `/courses/${previous.slug}` : null}
    nextUrl={next ? `/courses/${next.slug}` : null}
    comments={false}
  >
    <div class="not-prose mb-8 grid gap-4 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 md:grid-cols-2">
      <div>
        <p class="text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Course</p>
        <p class="mt-2 text-lg font-medium">{entry.data.course}</p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Note type</p>
        <p class="mt-2 text-lg font-medium">{entry.data.kind}</p>
      </div>
    </div>
    <Content />
  </ContentLayout>
</BaseLayout>
