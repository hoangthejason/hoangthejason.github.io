---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../components/BaseLayout.astro';
import ContentLayout from '../../components/ContentLayout.astro';
import { getNeighbors, getSortedCollection } from '../../lib/content';

export async function getStaticPaths() {
  const entries = await getCollection('datasets', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

interface Props {
  entry: CollectionEntry<'datasets'>;
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const entries = await getSortedCollection('datasets');
const { previous, next } = getNeighbors(entries, entry.slug);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <ContentLayout
    title={entry.data.title}
    description={entry.data.description}
    tags={entry.data.tags}
    date={entry.data.date}
    updatedDate={entry.data.updatedDate}
    readingTime={entry.data.readingTime}
    headings={headings}
    previous={previous}
    next={next}
    previousUrl={previous ? `/datasets/${previous.slug}` : null}
    nextUrl={next ? `/datasets/${next.slug}` : null}
    comments={false}
  >
    <div class="not-prose mb-8 grid gap-4 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 md:grid-cols-3">
      <div>
        <p class="text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Size</p>
        <p class="mt-2 text-lg font-medium">{entry.data.size}</p>
      </div>
      <div class="md:col-span-2">
        <p class="text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Tasks</p>
        <p class="mt-2 text-sm leading-7">{entry.data.tasks.join(', ')}</p>
      </div>
      <div class="md:col-span-3">
        <p class="text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Download links</p>
        <ul class="mt-3 flex flex-wrap gap-3">
          {entry.data.downloadLinks.map((link) => (
            <li>
              <a
                href={link.url}
                class="inline-flex rounded-lg border border-[var(--color-border)] px-3 py-2 text-sm font-medium text-[var(--color-brand)] hover:border-[var(--color-accent)]"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
    <Content />
  </ContentLayout>
</BaseLayout>
