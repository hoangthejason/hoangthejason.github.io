---
import BaseLayout from '../../components/BaseLayout.astro';
import NotebookViewer from '../../components/NotebookViewer.astro';
import CodeBlockEnhancer from '../../components/CodeBlockEnhancer.astro';

export async function getStaticPaths() {
  const modules = import.meta.glob('../../generated/notebooks/*.json', { eager: true });

  return Object.values(modules).map((module) => ({
    params: { slug: module.default.slug },
    props: { notebook: module.default }
  }));
}

const { notebook } = Astro.props;
---

<BaseLayout title={notebook.title} description={notebook.description}>
  <section class="max-w-4xl">
    <p class="text-sm uppercase tracking-[0.18em] text-[var(--color-muted)]">{notebook.section || 'Notebook'}</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight md:text-5xl">{notebook.title}</h1>
    {notebook.description && <p class="mt-4 text-lg leading-8 text-[var(--color-muted)]">{notebook.description}</p>}

    <div class="mt-5 flex flex-wrap gap-3 text-sm text-[var(--color-muted)]">
      {notebook.date && <span>{new Date(notebook.date).toLocaleDateString('en', { dateStyle: 'medium' })}</span>}
      <a href="/notebooks" class="text-[var(--color-brand)] underline underline-offset-4">All notebooks</a>
    </div>

    <div class="mt-10">
      <NotebookViewer cells={notebook.cells} />
    </div>
  </section>
  <CodeBlockEnhancer />
</BaseLayout>
