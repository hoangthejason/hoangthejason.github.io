---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../components/BaseLayout.astro';
import ContentLayout from '../../components/ContentLayout.astro';
import { getNeighbors, getSortedCollection } from '../../lib/content';

export async function getStaticPaths() {
  const entries = await getCollection('papers', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry }
  }));
}

interface Props {
  entry: CollectionEntry<'papers'>;
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const entries = await getSortedCollection('papers');
const { previous, next } = getNeighbors(entries, entry.slug);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <ContentLayout
    title={entry.data.title}
    description={entry.data.description}
    tags={entry.data.tags}
    date={entry.data.date}
    updatedDate={entry.data.updatedDate}
    readingTime={entry.data.readingTime}
    headings={headings}
    previous={previous}
    next={next}
    previousUrl={previous ? `/papers/${previous.slug}` : null}
    nextUrl={next ? `/papers/${next.slug}` : null}
    comments={false}
  >
    <div class="not-prose mb-8 grid gap-4 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 md:grid-cols-2">
      <div>
        <p class="text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Authors</p>
        <p class="mt-2 text-sm leading-7">{entry.data.authors.join(', ')}</p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Original paper</p>
        <a href={entry.data.paperLink} class="mt-2 inline-block text-sm font-medium text-[var(--color-brand)] underline underline-offset-4">
          Open source
        </a>
      </div>
      <div>
        <p class="text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Problem</p>
        <p class="mt-2 text-sm leading-7">{entry.data.problem}</p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Method</p>
        <p class="mt-2 text-sm leading-7">{entry.data.method}</p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Results</p>
        <p class="mt-2 text-sm leading-7">{entry.data.results}</p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-[0.16em] text-[var(--color-muted)]">Limitations</p>
        <p class="mt-2 text-sm leading-7">{entry.data.limitations}</p>
      </div>
    </div>
    <Content />
  </ContentLayout>
</BaseLayout>
