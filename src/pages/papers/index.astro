---
import BaseLayout from '../../components/BaseLayout.astro';
import PaperCard from '../../components/PaperCard.astro';
import { getSortedCollection } from '../../lib/content';

const notes = await getSortedCollection('papers');
---

<BaseLayout title="Papers" description="Paper summaries with structured fields for problem, method, results, limitations, and commentary.">
  <section>
    <p class="text-sm uppercase tracking-[0.18em] text-[var(--color-muted)]">Papers</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight md:text-5xl">Paper notes and summaries</h1>
    <p class="mt-4 max-w-3xl text-lg leading-8 text-[var(--color-muted)]">
      Structured notes for reading papers with enough detail to revisit methods and trade-offs quickly.
    </p>

    <div class="mt-10 space-y-4">
      {notes.map((entry) => (
        <PaperCard
          href={`/papers/${entry.slug}`}
          title={entry.data.title}
          authors={entry.data.authors}
          paperLink={entry.data.paperLink}
          problem={entry.data.problem}
          method={entry.data.method}
          results={entry.data.results}
          limitations={entry.data.limitations}
          date={entry.data.date}
          tags={entry.data.tags}
        />
      ))}
    </div>
  </section>
</BaseLayout>
