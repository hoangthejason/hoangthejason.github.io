---
import BaseLayout from '../../components/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getAllTags, getEntriesByTag, getCollectionLabel } from '../../lib/content';

export async function getStaticPaths() {
  const tags = await getAllTags();
  return tags.map((tag) => ({
    params: { tag: tag.slug },
    props: { tag }
  }));
}

const { tag } = Astro.props;
const entries = await getEntriesByTag(tag.slug);
---

<BaseLayout title={`Tag: ${tag.name}`} description={`Entries tagged with ${tag.name}.`}>
  <section>
    <p class="text-sm uppercase tracking-[0.18em] text-[var(--color-muted)]">Tag</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight md:text-5xl">{tag.name}</h1>
    <p class="mt-4 text-lg leading-8 text-[var(--color-muted)]">
      {tag.count} related {tag.count === 1 ? 'entry' : 'entries'} across the knowledge base.
    </p>

    <div class="mt-10 space-y-4">
      {entries.map(({ collection, entry }) => (
        <PostCard
          href={`/${collection}/${entry.slug}`}
          title={entry.data.title}
          description={entry.data.description}
          date={entry.data.date}
          tags={entry.data.tags}
          meta={getCollectionLabel(collection)}
        />
      ))}
    </div>
  </section>
</BaseLayout>
